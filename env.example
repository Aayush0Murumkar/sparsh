# ─── SheShield AI – Environment Variables ──────────────────────────────────
# Copy this file to .env before running locally.

# Local development (backend running at port 8000)
REACT_APP_API_URL=http://127.0.0.1:8000

# ── For production/Netlify ──────────────────────────────────────────────────
# Set REACT_APP_API_URL in your Netlify dashboard under:
#   Site Settings → Environment Variables
# Example:
# REACT_APP_API_URL=https://your-sheshield-backend.onrender.com
